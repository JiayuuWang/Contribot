# Contribot Configuration
# Copy this file to contribot.toml and edit as needed.

[general]
workspaces_dir = "./data/workspaces"
db_path = "./data/contribot.db"
log_dir = "./data/logs"
scan_interval_minutes = 60
max_concurrent_repos = 3
claude_model = "sonnet"
max_budget_per_task_usd = 0.50
dashboard_port = 3847

[github]
# Auto-detected from `gh auth status` if empty
username = ""

# ============================================================================
# Target Repositories
# ============================================================================
# Add one [[repos]] block per target repository.
#
# Field reference:
#
#   name (REQUIRED)
#     Format: "owner/repo". The GitHub repository to contribute to.
#
#   focus (optional, default: [] = unrestricted)
#     What types of contributions to make. When empty, Contribot will
#     contribute in ALL areas — bug fixes, tests, docs, refactoring,
#     features, and issue creation. Specify values to restrict:
#       "bug-fixes"      - Find and fix bugs from open issues
#       "tests"          - Add missing test coverage
#       "documentation"  - Improve docs, READMEs, comments
#       "refactoring"    - Clean up code duplication, dead code
#       "features"       - Implement small feature requests
#       "issues"         - Proactively create new issues when problems are found
#
#   reasons (optional, default: "")
#     Why you want to contribute. Passed to Claude as context to help it
#     understand your perspective and make better contribution decisions.
#     Example: "I use this library daily and want to improve error messages"
#
#   issue_labels (optional, default: [] = no filter)
#     GitHub issue labels to filter when scanning for issues to fix.
#     When empty, ALL open issues are considered (no label restriction).
#     Specify labels to narrow the scope:
#       e.g. ["good first issue", "help wanted", "bug"]
#
#   max_prs_per_day (optional, default: 2)
#     Maximum number of PRs to create per day for this repo.
#     Set to 0 to pause PR creation while still allowing scans.
#     Prevents overwhelming maintainers with too many automated PRs.
#
#   enabled (optional, default: true)
#     Set to false to skip this repo entirely during scan cycles.
#     The repo stays in config but is ignored by the orchestrator.
#
# ============================================================================

# Minimal example — contributes in all areas, scans all issues:
# [[repos]]
# name = "owner/repo"

# Restricted example — only fix bugs from "help wanted" issues:
# [[repos]]
# name = "owner/repo"
# focus = ["bug-fixes"]
# issue_labels = ["help wanted"]
# reasons = "I use this library daily and want to improve error messages"
# max_prs_per_day = 2
# enabled = true
